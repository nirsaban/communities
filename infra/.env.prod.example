# Production env template. Copy to .env.prod on the VPS and fill in real values.
# Do NOT commit .env.prod — it's gitignored.

# --- API base URL (the public origin the mobile + web apps talk to) ---
# Pre-domain: use the VPS IP (http://72.62.154.127:3010)
# Post-domain + TLS: use https://api.yourdomain.com
API_BASE_URL=http://72.62.154.127:3010

# --- Web base URL (where the PWA is served) ---
# Used by the backend when generating links in emails (community invites point
# to ${WEB_BASE_URL}/invite/<token>).
# Pre-domain: use the VPS IP on the web port (http://72.62.154.127:3011)
# Post-domain + TLS: use https://app.yourdomain.com
WEB_BASE_URL=http://72.62.154.127:3011

# --- CORS ---
# Comma-separated list of origins allowed to call the API. With the web PWA on
# the same VPS, '*' is fine for now. Tighten by listing the exact origins
# (e.g. https://app.yourdomain.com) once a domain is attached.
CORS_ORIGINS=*

# --- JWT secrets (generate with: openssl rand -hex 32) ---
JWT_ACCESS_SECRET=REPLACE_WITH_RANDOM_32_BYTE_HEX
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_RANDOM_32_BYTE_HEX
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- Logging ---
LOG_LEVEL=info

# --- Mail (stub for now; swap to a real provider before launch) ---
MAIL_DRIVER=console

# --- Storage (local volume; swap to Cloudinary or S3 before launch) ---
STORAGE_DRIVER=local

# --- Payment gateway ---
# Stripe block — kept temporarily while the PayPlus migration is in flight.
# Once the PayPlus PR merges, replace these with PAYPLUS_* vars (see
# the PR description for the full list).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
