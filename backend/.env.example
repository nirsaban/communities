# --- Server ---
NODE_ENV=development
PORT=4242
API_BASE_URL=http://localhost:4242

# --- MongoDB ---
# Local Docker:    mongodb://mongo:27017/community
# Local host:      mongodb://localhost:27017/community
# Atlas:           mongodb+srv://USER:PASS@cluster.mongodb.net/community
MONGO_URI=mongodb://localhost:27017/community

# --- JWT ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=change-me-to-a-32-byte-hex-string
JWT_REFRESH_SECRET=change-me-to-a-different-32-byte-hex
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- Password reset ---
PASSWORD_RESET_TTL_MINUTES=30

# --- Rate limit ---
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_READ_MAX=200
RATE_LIMIT_WRITE_MAX=60

# --- CORS ---
# Comma-separated. Use "*" only for local dev.
CORS_ORIGINS=*

# --- Mail (dev: console) ---
MAIL_FROM=no-reply@example.com
MAIL_DRIVER=console

# --- Storage ---
# local      → write to UPLOAD_DIR and serve from /uploads (dev default)
# cloudinary → upload via Cloudinary SDK; requires the three CLOUDINARY_* keys
STORAGE_DRIVER=local
UPLOAD_DIR=./uploads
MAX_UPLOAD_BYTES=524288000
# Required when STORAGE_DRIVER=cloudinary. Get these from
# https://cloudinary.com/console → API Keys.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Top-level Cloudinary folder all assets are uploaded under.
CLOUDINARY_UPLOAD_FOLDER=communities

# --- Google OAuth (§1.3) ---
# Set all three to enable Google sign-in. Get them from
# https://console.cloud.google.com/apis/credentials. The redirect URI must
# match the one registered with Google exactly.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5173/auth/google/callback

# --- PayPlus (Israeli gateway, platform-managed v1) ---
# Credentials from https://dashboard.payplus.co.il → Account → API. In production these
# three vars are required; in dev leave them blank and set PAYPLUS_SANDBOX_MODE=true.
PAYPLUS_API_KEY=
PAYPLUS_SECRET_KEY=
# Page request UID identifies the hosted-page template (set up once in the PayPlus dashboard).
PAYPLUS_PAGE_REQUEST_UID=
# HMAC-SHA256 secret used to verify x-payplus-signature headers on /api/v1/webhooks/payplus.
PAYPLUS_WEBHOOK_SECRET=
PAYPLUS_API_BASE_URL=https://restapi.payplus.co.il/api/v1.0
# When true (the default in dev), outbound calls log to stdout instead of hitting the network.
PAYPLUS_SANDBOX_MODE=true

# --- Payment policy ---
# ILS is the only supported currency at v1; PayPlus expects amounts in agorot (cents).
PAYMENT_CURRENCY=ILS
# Maximum number of monthly installments offered to buyers (PayPlus תשלומים). Max 12.
PAYMENT_MAX_INSTALLMENTS=12

# --- Platform payment redirects ---
# PayPlus posts webhooks to NOTIFY_URL; redirects users to SUCCESS_URL / FAILURE_URL after a payment attempt.
# Use ngrok or similar to expose NOTIFY_URL during local dev (see docs/RUNBOOK.md).
PLATFORM_PAYMENT_NOTIFY_URL=http://localhost:3000/api/v1/webhooks/payplus
PLATFORM_PAYMENT_SUCCESS_URL=http://localhost:3000/api/v1/payments/success
PLATFORM_PAYMENT_FAILURE_URL=http://localhost:3000/api/v1/payments/failure

# --- Logging ---
LOG_LEVEL=info
