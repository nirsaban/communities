# --- Server ---
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# --- MongoDB ---
# Local Docker:    mongodb://mongo:27017/community
# Local host:      mongodb://localhost:27017/community
# Atlas:           mongodb+srv://USER:PASS@cluster.mongodb.net/community
MONGO_URI=mongodb://localhost:27017/community

# --- JWT ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=change-me-to-a-32-byte-hex-string
JWT_REFRESH_SECRET=change-me-to-a-different-32-byte-hex
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- Password reset ---
PASSWORD_RESET_TTL_MINUTES=30

# --- Rate limit ---
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_READ_MAX=200
RATE_LIMIT_WRITE_MAX=60

# --- CORS ---
# Comma-separated. Use "*" only for local dev.
CORS_ORIGINS=*

# --- Mail (dev: console) ---
MAIL_FROM=no-reply@example.com
MAIL_DRIVER=console

# --- Storage (dev: local disk) ---
STORAGE_DRIVER=local
UPLOAD_DIR=./uploads
MAX_UPLOAD_BYTES=524288000

# --- Stripe (test mode) ---
# Test secret key from https://dashboard.stripe.com/test/apikeys (sk_test_...)
STRIPE_SECRET_KEY=
# Webhook signing secret from `stripe listen --forward-to localhost:3000/api/v1/webhooks/stripe`
STRIPE_WEBHOOK_SECRET=
# Stripe API version pin (change deliberately; impacts request/response shape)
STRIPE_API_VERSION=2025-09-30.clover
# Platform fee in basis points (500 = 5%) charged on community payments via application_fee_amount
STRIPE_PLATFORM_FEE_BPS=500
# Pre-created Stripe Price IDs for subscriptions (create via dashboard or `stripe prices create`)
STRIPE_SUBSCRIPTION_MONTHLY_PRICE_ID=
STRIPE_SUBSCRIPTION_ANNUAL_PRICE_ID=
# Where Stripe redirects after Checkout (must include {CHECKOUT_SESSION_ID} placeholder for success_url)
CHECKOUT_SUCCESS_URL=http://localhost:3000/payments/success?session_id={CHECKOUT_SESSION_ID}
CHECKOUT_CANCEL_URL=http://localhost:3000/payments/cancel

# --- Logging ---
LOG_LEVEL=info
