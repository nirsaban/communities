{
  "screen": "SubscriptionPlans",
  "route": "/subscribe",
  "roles": [
    "member"
  ],
  "components": [
    {
      "name": "CloseButton",
      "type": "iconButton"
    },
    {
      "name": "Title",
      "type": "text",
      "style": "displayMedium"
    },
    {
      "name": "BillingToggle",
