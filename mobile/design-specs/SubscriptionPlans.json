      "width": "full"
    }
  ],
  "states": [
    "default"
  ],
  "conditionalVisibility": [],
  "colors": {
    "background": "var(--bg)",
    "accent": "var(--accent)"
  },
  "spacing": {
    "pagePadding": 20,
    "sectionGap": 16
  },
  "interactions": [
    "BillingToggle → annual/monthly with savings tag",
    "SubscribeButton → Stripe checkout → success"
  ]
