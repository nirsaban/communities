{
  "screen": "ForgotPassword",
  "route": "/forgot",
  "roles": [
    "member",
    "admin",
    "subadmin",
    "event_manager",
    "super_admin"
  ],
  "components": [
    {
      "name": "BackButton",
      "type": "iconButton"
    },
    {
      "name": "IconBlob",
      "type": "icon",
      "height": 96,
      "width": 96,
      "borderRadius": 30
    },
    {
      "name": "Title",
      "type": "text",
      "style": "displayMedium",
      "color": "onBackground"
    },
    {
      "name": "Body",
      "type": "text",
      "style": "bodyLarge",
      "color": "muted"
    },
    {
      "name": "EmailField",
      "type": "textField"
    },
    {
      "name": "SendResetButton",
      "type": "button",
      "style": "primary",
      "width": "full",
      "height": 50
    },
    {
      "name": "BackToLoginButton",
      "type": "button",
      "style": "ghost"
    }
  ],
  "states": [
    "default",
    "focused",
    "loading",
    "sent"
  ],
  "conditionalVisibility": [],
  "colors": {
    "background": "var(--bg)",
    "accent": "var(--accent)"
  },
  "spacing": {
    "pagePadding": 20,
    "sectionGap": 24
  },
  "interactions": [
    "SendResetButton → 'check inbox' confirmation with 60s resend cooldown (no account enumeration)"
  ]
}
