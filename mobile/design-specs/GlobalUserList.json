    "background": "var(--bg)",
    "accent": "var(--accent)"
  },
  "spacing": {
    "pagePadding": 20,
    "sectionGap": 0
  },
  "theme": "dark",
  "interactions": [
    "SearchField → email/name across all tenants",
    "UserRow → user detail",
    "disabled accounts dimmed"
