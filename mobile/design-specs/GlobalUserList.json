{
  "screen": "GlobalUserList",
  "route": "/super/users",
  "roles": [
    "super_admin"
  ],
  "components": [
    {
      "name": "FilterButton",
      "type": "iconButton"
    },
    {
      "name": "SearchField",
      "type": "search"
    },
    {
      "name": "RoleFilterChips",
      "type": "chipGroup"
    },
    {
