{
  "screen": "ResetPassword",
  "route": "/reset",
  "roles": [
    "member",
    "admin",
    "subadmin",
    "event_manager",
    "super_admin"
  ],
  "components": [
    {
      "name": "BackButton",
      "type": "iconButton"
    },
    {
      "name": "Title",
      "type": "text",
      "style": "displayMedium",
      "color": "onBackground"
    },
    {
      "name": "NewPasswordField",
      "type": "textField",
      "trailing": "revealToggle"
    },
    {
      "name": "PasswordStrengthMeter",
      "type": "progress"
    },
    {
      "name": "ConfirmPasswordField",
      "type": "textField"
    },
    {
      "name": "UpdatePasswordButton",
      "type": "button",
      "style": "primary",
      "width": "full",
      "height": 50
    }
  ],
  "states": [
    "default",
    "focused",
    "error"
  ],
  "conditionalVisibility": [],
  "colors": {
    "background": "var(--bg)",
    "accent": "var(--accent)"
  },
  "spacing": {
    "pagePadding": 20,
    "sectionGap": 16
  },
  "interactions": [
    "UpdatePasswordButton → sign in + route home",
    "liveValidation → strength + match"
  ]
}
