{
  "screen": "RSVPConfirmation",
  "route": "/events/:id/rsvp",
  "roles": [
    "member"
  ],
  "components": [
    {
      "name": "CloseButton",
      "type": "iconButton"
    },
    {
      "name": "SuccessBlob",
      "type": "icon",
      "color": "success"
    },
    {
      "name": "Title",
      "type": "text",
      "style": "displayMedium"
    },
    {
      "name": "EventSummaryCard",
      "type": "card"
    },
    {
      "name": "AddToCalendarButton",
      "type": "button",
      "style": "primary"
    },
    {
      "name": "ShareChips",
