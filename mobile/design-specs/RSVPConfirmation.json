    }
  ],
  "states": [
    "populated"
  ],
  "conditionalVisibility": [],
  "colors": {
    "background": "var(--bg)",
    "accent": "var(--accent)"
  },
  "spacing": {
    "pagePadding": 20,
    "sectionGap": 16
  },
  "interactions": [
    "AddToCalendarButton → generates .ics",
    "ShareChips → invite friend",
    "spring-scale check on entry"
